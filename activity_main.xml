<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:src="@drawable/logo"
        android:scaleType="centerCrop"/>

    <TextView
        style="@style/EstiloTexto"
        android:text="Faça seu pedido"/>

    <EditText
        android:id="@+id/nome"
        android:hint="Digite seu nome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/bacon"
        android:text="Bacon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/queijo"
        android:text="Queijo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <CheckBox
        android:id="@+id/onion"
        android:text="Onion Rings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        style="@style/EstiloTexto"
        android:text="Quantidade"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <Button
            android:text="-"
            android:onClick="subtrair"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/qtd"
            android:text="1"
            android:textSize="18sp"
            android:padding="16dp"/>

        <Button
            android:text="+"
            android:onClick="somar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <TextView
        style="@style/EstiloTexto"
        android:text="Preço Total"/>

    <TextView
        android:id="@+id/preco"
        android:text="R$ 20"
        android:textSize="18sp"/>

    <TextView
        style="@style/EstiloTexto"
        android:text="Resumo do Pedido"/>

    <TextView
        android:id="@+id/resumo"
        android:text=""/>

    <Button
        android:text="Enviar Pedido"
        android:onClick="enviarPedido"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    
    <Button
    android:text="Ver Carrinho"
    android:onClick="abrirCarrinho"
    android:backgroundTint="#EA1D2C"
    android:textColor="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"/>    

</LinearLayout>
</ScrollView>